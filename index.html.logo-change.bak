<body>`n    <a class="skip-link" href="#main">Pular para o conteúdo</a>
    <div class="container" id="main">
        <!-- Header -->
        <header>
            <div class="header-content">
                <div class="logo-section">
                    <div class="logo-icon">CE</div>
                    <div class="logo-text">
                        <h1>Controle de Estoque</h1>
                        
                    </div>
                </div>
                
                <div class="header-search">
                    <input type="text" id="buscaGlobal" placeholder="ðŸ” Buscar produtos, contratos, lojas..." oninput="executarBuscaGlobal(this.value)">
                </div>
                <div class="header-info">
                    <div class="header-stat">
                        <div class="stat-value" id="totalProdutos">0</div>
