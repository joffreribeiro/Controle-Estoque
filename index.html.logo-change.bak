                                            <input type="text" id="valorTotalVenda" readonly class="readonly-field highlight-field">
                                        </div>
                                    </div>
                                </section>

                                <section id="sec-observacoes" class="form-section">
                                    <div class="form-group">
                                        <label for="observacoesVenda">ObservaÃ§Ãµes</label>
                                        <textarea id="observacoesVenda" rows="3" placeholder="ObservaÃ§Ãµes adicionais sobre a venda..."></textarea>
                                    </div>
                                </section>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-outline" onclick="fecharModal('modalVendaDetalhada')">Cancelar</button>
                        <button type="submit" class="btn btn-success">ðŸ’¾ Salvar Venda</button>
                    </div>
                </form>
            </div>
        </div>

        <!-- Modal Nova DistribuiÃ§Ã£o Detalhada -->
        <div id="modalNovaDistribuicao" class="modal">
            <div class="modal-content">
                <div class="modal-header">
                    <h2><span>ðŸšš</span> Nova DistribuiÃ§Ã£o</h2>
                    <span class="close" onclick="fecharModal('modalNovaDistribuicao')">&times;</span>
                </div>
                <form id="formNovaDistribuicao" onsubmit="salvarNovaDistribuicao(event)">
