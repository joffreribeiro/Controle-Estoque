        <!-- Modal Novo Produto -->
        <div id="modalProduto" class="modal">
            <div class="modal-content">
                <div class="modal-header">
                    <h2><span>+</span> Adicionar Novo Produto</h2>
                    <span class="close" onclick="fecharModal('modalProduto')">&times;</span>
                </div>
                <form id="formProduto" onsubmit="salvarProduto(event)">
                    <div class="modal-body">
                        <div class="form-group">
                            <label for="nomeProduto">Nome do Produto <span class="required">*</span></label>
                            <input type="text" id="nomeProduto" required placeholder="Ex: CARABINA IA2 5,56">
                        </div>
                        <div class="form-row">
                            <div class="form-group">
                                <label for="estoqueTotal">Quantidade <span class="required">*</span></label>
                                <input type="number" id="estoqueTotal" required min="0" placeholder="0">
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-outline" onclick="fecharModal('modalProduto')">Cancelar</button>
                        <button type="submit" class="btn btn-primary">Salvar Produto</button>
                    </div>
                </form>
            </div>
        </div>

        <!-- Modal Entrada de Estoque -->
        <div id="modalEntradaEstoque" class="modal">
            <div class="modal-content">
                <div class="modal-header">
                    <h2><span>ðŸ“¥</span> Entrada de Estoque (IMBEL)</h2>
