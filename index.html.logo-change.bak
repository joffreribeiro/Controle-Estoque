                        <span class="fs-dot fs-offline" id="fsDot"></span>
                        <span class="fs-text" id="fsText">Cloud: desconectado</span>
                    </div>
                    <!-- Login button + modal -->
                    <div id="authPanel" class="auth-panel">
                        <button id="openLoginBtn" class="btn btn-outline btn-sm" onclick="openLoginModal()">Login</button>

                        <div id="authSignedIn" class="auth-signedin" aria-hidden="true" style="align-items:center; gap:8px;">
                            <span id="authUserDisplay" style="font-weight:600"></span>
                            <button class="btn btn-outline btn-sm" id="btnAuthSignOut" onclick="signOut()">Sair</button>
                        </div>

                        <!-- Modal de Login -->
                        <div id="loginModal" class="modal" aria-hidden="true">
                            <div class="modal-backdrop" onclick="closeLoginModal()"></div>
                            <div class="modal-content" role="dialog" aria-modal="true">
                                <button class="modal-close" onclick="closeLoginModal()">Ã—</button>
                                <div class="login-card">
                                    <div class="login-card-icon">ðŸ“‹</div>
                                    <h2 class="login-card-title">Acesso Administrador</h2>
                                    <p class="login-card-sub">FaÃ§a login para editar dados</p>

                                    <form id="authPanelForm" onsubmit="event.preventDefault(); signIn(); closeLoginModal();">
                                        <div class="form-group">
                                            <label for="authEmail">Email</label>
                                            <input type="email" id="authEmail" placeholder="seu@email.com" autocomplete="username" required>
                                        </div>

                                        <div class="form-group">
                                            <label for="authPassword">Senha</label>
                                            <div class="password-row">
                                                <input type="password" id="authPassword" placeholder="senha" autocomplete="current-password" required>
                                                <label class="show-pass">
                                                    <input type="checkbox" id="toggleShowPassword" onclick="togglePasswordVisibility()"> Mostrar
                                                </label>
                                            </div>
                                        </div>

                                        <div class="form-actions">
                                            <button type="submit" class="btn btn-primary btn-block">Entrar</button>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                    <!-- Logged account short info (persistent visual) -->
                    <div id="loggedAccountInfo" class="logged-account-info" title="Conta logada" style="margin-left:12px; font-size:13px;">
                        <span id="loggedAccountEmail" style="font-weight:600"></span>
                        <span id="loggedAccountBadge" style="margin-left:8px; display:none; padding:2px 6px; background:#2b8aef; color:#fff; border-radius:4px; font-size:11px;">ADMIN</span>
                    </div>
                </div>
            </div>
        </header>

        <!-- NavegaÃ§Ã£o por Abas -->
