        <!-- Modal Venda -->
        <div id="modalVenda" class="modal">
            <div class="modal-content">
                <div class="modal-header">
                    <h2><span>ðŸ’°</span> Registrar Venda</h2>
                    <span class="close" onclick="fecharModal('modalVenda')">&times;</span>
                </div>
                <form id="formVenda" onsubmit="salvarVenda(event)">
                    <div class="modal-body">
                        <div class="form-group">
                            <label for="produtoVenda">Produto <span class="required">*</span></label>
                            <select id="produtoVenda" required>
                                <option value="">Selecione um produto</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label for="vendedorVenda">Vendedor <span class="required">*</span></label>
                            <select id="vendedorVenda" required>
                                <option value="">Selecione o vendedor</option>
                                <option value="KOLTE">KOLTE</option>
                                <option value="ISA">ISA</option>
                                <option value="LC">LC</option>
                                <option value="ADES">ADES</option>
                                <option value="FL">FL</option>
                                <option value="IMBEL">IMBEL (Venda Direta)</option>
                            </select>
                        </div>
                        <div class="form-group">
