    <!-- Modal HistÃ³rico -->
    <div id="modalHistorico" class="modal">
        <div class="modal-content modal-lg">
            <div class="modal-header">
                <h2><span>ðŸ“‹</span> HistÃ³rico de AlteraÃ§Ãµes</h2>
