                            <label for="produtoEntrada">Produto <span class="required">*</span></label>
                            <select id="produtoEntrada" required onchange="mostrarEstoqueAtual()">
                                <option value="">Selecione um produto</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label>Estoque Atual na IMBEL</label>
