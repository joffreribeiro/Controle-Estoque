                        <div class="form-group">
                            <label for="observacoesDistDet">ObservaÃ§Ãµes</label>
                            <textarea id="observacoesDistDet" rows="2" placeholder="ObservaÃ§Ãµes sobre a distribuiÃ§Ã£o..."></textarea>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-outline" onclick="fecharModal('modalNovaDistribuicao')">Cancelar</button>
                        <button type="submit" class="btn btn-info">ðŸšš Registrar DistribuiÃ§Ã£o</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Modal Fechamentos de ComissÃµes -->
    <div id="modalFechamentosComissoes" class="modal">
        <div class="modal-content modal-lg">
            <div class="modal-header">
                <h2><span>ðŸ§Š</span> Fechamentos Mensais de ComissÃµes</h2>
